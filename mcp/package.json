{
  "name": "@syenite/mcp",
  "version": "0.4.0",
  "mcpName": "io.github.syenite-ai/syenite",
  "description": "The DeFi interface for AI agents — swap routing, bridge execution, yield intelligence, lending rates, and risk assessment via MCP",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "syenite-generate-key": "dist/scripts/generate-key.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node -e \"require('fs').cpSync('src/web/docs', 'dist/web/docs', { recursive: true })\" && node -e \"require('fs').cpSync('assets', 'dist/assets', { recursive: true })\"",
    "start": "node dist/index.js",
    "generate-key": "tsx src/scripts/generate-key.ts"
  },
  "keywords": [
    "mcp",
    "defi",
    "swap",
    "bridge",
    "yield",
    "lending",
    "ai-agents",
    "aave",
    "morpho",
    "lifi"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/syenite-ai/syenite.git",
    "directory": "mcp"
  },
  "homepage": "https://syenite.ai",
  "bugs": {
    "url": "https://github.com/syenite-ai/syenite/issues"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "viem": "^2.47.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
