{
  "name": "@syenite/mcp",
  "version": "0.5.1",
  "mcpName": "io.github.syenite-ai/syenite",
  "description": "Composable DeFi intelligence for AI agents — swap routing, bridge execution, yield, lending, prediction markets, wallet ops, and gas estimation across 30+ chains via MCP",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "syenite": "dist/stdio.js",
    "syenite-generate-key": "dist/scripts/generate-key.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node -e \"require('fs').cpSync('src/web/docs', 'dist/web/docs', { recursive: true })\" && node -e \"require('fs').cpSync('assets', 'dist/assets', { recursive: true })\"",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-key": "tsx src/scripts/generate-key.ts",
    "register-agent": "tsx src/scripts/register-agent.ts",
    "register-agent:ethereum": "tsx src/scripts/register-agent.ts --chain=ethereum",
    "register-agent:arbitrum": "tsx src/scripts/register-agent.ts --chain=arbitrum",
    "register-agent:bnb": "tsx src/scripts/register-agent.ts --chain=bnb",
    "register-agent:dry-run": "tsx src/scripts/register-agent.ts --dry-run",
    "bridge-funds": "tsx src/scripts/bridge-funds.ts",
    "bridge-funds:dry-run": "tsx src/scripts/bridge-funds.ts --dry-run",
    "migrate:usage-logs-v06": "tsx src/scripts/migrate-usage-logs-v06.ts",
    "hash-legacy-ips": "tsx src/scripts/hash-legacy-ips.ts",
    "hash-legacy-ips:dry-run": "tsx src/scripts/hash-legacy-ips.ts --dry-run",
    "read-v0.6-signal": "tsx src/scripts/read-v0.6-signal.ts"
  },
  "keywords": [
    "mcp",
    "defi",
    "swap",
    "bridge",
    "yield",
    "lending",
    "ai-agents",
    "aave",
    "morpho",
    "lifi",
    "prediction-markets",
    "polymarket",
    "compound",
    "fluid",
    "carry-trade",
    "erc-8004"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/syenite-ai/syenite.git",
    "directory": "mcp"
  },
  "homepage": "https://syenite.ai",
  "bugs": {
    "url": "https://github.com/syenite-ai/syenite/issues"
  },
  "files": [
    "dist",
    "README.md",
    "server.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pg": "^8.13.1",
    "viem": "^2.47.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
