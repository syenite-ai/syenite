ALCHEMY_API_KEY=your_alchemy_api_key_here
ADMIN_PASSWORD=change_this_to_a_secure_password
# On DigitalOcean App Platform, set DASHBOARD_PASSWORD at app-level instead (avoids component override)
# DASHBOARD_PASSWORD=your_dashboard_password
PORT=3000
# Postgres (required in production). On DO App Platform, DATABASE_URL is set from the linked managed DB.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# Optional: seed a persistent API key on startup
SEED_API_KEY=sk_your_persistent_key_here
# Li.Fi swap/bridge routing — register at portal.li.fi for fee collection
LIFI_INTEGRATOR=syenite
LIFI_FEE=0.0015
